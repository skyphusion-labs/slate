# Slate production stack -- example environment file.
#
# Copy this file to stacks/.env and fill in your own values:
#   cp stacks/.env.example stacks/.env
#
# docker compose auto-loads stacks/.env for compose.prod.yml. stacks/.env is
# gitignored and MUST NOT be committed. The values here are placeholders only;
# no real deployment id or secret belongs in this tracked file.

# --- Non-secret identifiers (your deployment topology) --------------------
# Comma-separated Discord channel IDs the bot listens in.
DISCORD_CHANNEL_IDS=000000000000000000
# Cloudflare account ID that owns the D1 database.
CF_D1_ACCOUNT_ID=your-cloudflare-account-id
# D1 database ID (UUID) backing the screenwriter state.
CF_D1_DATABASE_ID=00000000-0000-0000-0000-000000000000

# --- Secrets (never share, never commit) ----------------------------------
# Discord bot token.
DISCORD_TOKEN=
# Cloudflare Access service token (protects the vivijure/LLM origins).
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
# Cloudflare API token with D1:Write on the database above.
CF_D1_TOKEN=
# Cloudflare AI Gateway (Anthropic path). Set both to use Claude; leave unset
# to fall back to Ollama (see OLLAMA_BASE_URL).
CF_AIG_TOKEN=
CF_GATEWAY_ENDPOINT=
# R2 credentials for portrait uploads via the LLM API.
CF_R2_ACCESS_ID=
CF_R2_SECRET=

# --- Optional overrides (compose provides safe defaults) -------------------
# Model id used for the main conversation.
# DISCORD_MODEL=claude-sonnet-4-6
# Ollama base URL, used when CF_AIG_TOKEN is unset.
# OLLAMA_BASE_URL=http://localhost:11434/v1
# vivijure-search Worker base URL + shared secret.
# SEARCH_WORKER_URL=
# SEARCH_SECRET=
# Comma-separated bot IDs whose messages are trusted.
# TRUSTED_BOT_IDS=
# Structured log shipping (log-worker) URL + shared secret + service label.
# LOG_WORKER_URL=
# LOG_SECRET=
# LOG_SERVICE=slate
